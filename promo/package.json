{
  "name": "vibeterminal-promo",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion promo video for VibeTerminal",
  "scripts": {
    "studio": "remotion studio",
    "music": "node scripts/make-music.mjs && ffmpeg -y -loglevel error -i public/music.wav -codec:a libmp3lame -b:a 192k public/music.mp3 && rm public/music.wav",
    "render": "remotion render Promo out/vibeterminal-promo.mp4",
    "still": "remotion still Promo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "4.0.496",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.496"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
